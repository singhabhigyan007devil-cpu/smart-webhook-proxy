# HookShield Production Environment variables
# Copy this file to .env.production and fill in the values

# ==============================================================================
# Database (Automatically configured for the docker-compose PostgreSQL instance)
# ==============================================================================
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/hookshield

# ==============================================================================
# JWT Authentication & Security
# ==============================================================================
# Generate a strong, random 256-bit secret key (e.g., using `openssl rand -hex 32`)
JWT_SECRET=supersecret_linear_theme_key_change_me_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==============================================================================
# SMTP Mailer Settings (Required for actual Password Reset Emails)
# ==============================================================================
# Instructions:
# - For Gmail: Create an "App Password" in your Google Account security settings.
# - For SendGrid/Resend: Use their SMTP host and your generated API key.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@hookshield.io

# ==============================================================================
# OAuth Settings (For Google & GitHub Integration)
# ==============================================================================
# Instructions:
# - Google: Go to Google Cloud Console > APIs & Services > Credentials > Create OAuth Client ID.
# - GitHub: Go to Developer Settings > OAuth Apps > New OAuth App.
# If these are empty, HookShield will run in "mock callback" mode for testing.
GOOGLE_CLIENT_ID=your-google-client-id
GITHUB_CLIENT_ID=your-github-client-id

# ==============================================================================
# Frontend Settings
# ==============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
