# HookShield Configuration File

# Database
DATABASE_URL=sqlite+aiosqlite:///./hookshield.db

# JWT Token configuration
JWT_SECRET=supersecret_linear_theme_key_change_me_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- SMTP Settings (For actual password reset email dispatch) ---
# Replace with your actual SMTP server details (e.g. Gmail SMTP requires an App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@hookshield.io

# --- OAuth Settings (For Google & GitHub Integration) ---
# Add your client IDs and secrets here. If missing, HookShield runs in mock callback mode.
GOOGLE_CLIENT_ID=
GITHUB_CLIENT_ID=
